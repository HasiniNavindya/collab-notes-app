# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/collab-notes
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/collab-notes
MONGO_URI=mongodb://localhost:27017/collab-notes

# JWT Secret Key
# Generate a secure random string for production
# Example: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000
