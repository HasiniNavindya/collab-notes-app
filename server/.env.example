# MongoDB Configuration
# For local MongoDB use: mongodb://localhost:27017/collab-notes
# For MongoDB Atlas use: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGO_URI=mongodb://localhost:27017/collab-notes

# JWT Secret Key
# Generate a secure random string for production using: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Server Port
PORT=5000
